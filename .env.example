# Copy to .env and fill in. Auto-cargado por dpd.config al importar.

# ── Base de datos (MySQL) — solo local ──
# Conexión a payments_db (docker-compose en ~/Desktop/wks/local-infra)
DB_HOST=localhost
DB_PORT=3306
DB_NAME=payments_db
DB_USER=vaas
DB_PASSWORD=vaas

# ── Base de datos (MySQL) — tests de integración ──
# Misma instancia, DB aislada. Usar con pytest -m integration
#TEST_DB_HOST=localhost
#TEST_DB_PORT=3306
#TEST_DB_NAME=payments_db_test
#TEST_DB_USER=vaas
#TEST_DB_PASSWORD=vaas

# ── AWS Secrets Manager — Lambda/Batch ──
SECRET_NAME=

# ── AWS SNS ──
SNS_RESPONSE_TOPIC_ARN=

# ── AWS Batch ──
# Umbral de filas del loan tape a partir del cual se deriva el procesamiento a Batch (default: 5000)
BATCH_ROW_THRESHOLD=5000
BATCH_JOB_QUEUE=
BATCH_JOB_DEFINITION=

# ── AWS (local) ──
# Perfil de AWS CLI para uso local. Vacío = credenciales por defecto del entorno.
AWS_PROFILE_NAME=
